exports[`create > snapshots generated Node.js scaffold output 1`] = `
{
  ".dockerignore": ".git
node_modules
dist
",
  ".gitignore": "dist
node_modules
.env
",
  "Dockerfile": "FROM node:22-alpine AS base
WORKDIR /app

FROM base AS package-manager
RUN corepack enable pnpm 

FROM package-manager AS dev
COPY package.json pnpm-lock.yaml ./
RUN pnpm install
COPY src/ ./src/
COPY tsconfig.json ./
CMD ["pnpm","run","dev"]
",
  "Procfile": "web: node dist/index.js
",
  "README.md": "# snapshot-node-app

Generated by Universe CLI.
",
  "docker-compose.dev.yml": "services:
  app:
    build:
      context: ./
      target: dev
    develop:
      watch:
        - action: sync
          path: ./src
          target: /app/src
        - action: rebuild
          path: ./package.json
        - action: rebuild
          path: ./pnpm-lock.yaml
    ports:
      - 3000:3000
",
  "package.json": "{"dependencies":{"express":"^5"},"devDependencies":{"@types/express":"^5","@types/node":"^24","tsx":"^4","typescript":"^5"},"name":"snapshot-node-app","private":true,"scripts":{"build":"tsc -p tsconfig.json","dev":"tsx src/index.ts","preinstall":"npx only-allow pnpm","start":"node dist/index.js"},"type":"module"}",
  "platform.yaml": "domain:
  preview: snapshot-node-app.preview.example.com
  production: snapshot-node-app.example.com
environments:
  preview:
    branch: preview
  production:
    branch: main
name: snapshot-node-app
owner: platform-engineering
resources:
  - postgresql
  - redis
schemaVersion: "1"
services:
  - analytics
  - auth
  - email
stack: app
",
  "pnpm-workspace.yaml": "blockExoticSubdeps: true
minimumReleaseAge: 4320 # packages under 3 days old are simply rejected.
trustPolicy: no-downgrade
trustPolicyIgnoreAfter: 20160 # packages between 3 and 14 days old with no signature are also rejected.
engineStrict: true
",
  "src/index.ts": "import express from "express";

const app = express();

app.get("/", (_req, res) => {
  res.json({ name: "snapshot-node-app", status: "ok" });
});

app.listen(3000, () => {
  console.log("Universe app running on http://localhost:3000");
});
",
  "tsconfig.json": "{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "strict": true,
    "target": "ES2022"
  },
  "include": ["src/**/*"]
}
",
  "universe/services/analytics.md": "Analytics service selected for snapshot-node-app.
",
  "universe/services/auth.md": "Auth service selected for snapshot-node-app.
",
  "universe/services/email.md": "Email service selected for snapshot-node-app.
