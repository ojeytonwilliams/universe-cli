{
  "name": "universe",
  "version": "1.5.0",
  "description": "",
  "keywords": [],
  "license": "BSD-3-Clause",
  "author": "",
  "bin": {
    "universe": "dist/bin.js"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "start": "node dist/bin.js",
    "test": "vitest run",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.17.3",
    "typescript": "5.9.3",
    "vitest": "3.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "!*.{js,jsx,ts,tsx,mjs,cjs}": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.32.1"
}
