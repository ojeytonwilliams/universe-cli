{
  "name": "universe",
  "version": "3.24.0",
  "description": "",
  "keywords": [],
  "license": "BSD-3-Clause",
  "author": "",
  "bin": {
    "universe": "dist/bin.js"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:bundle": "tsdown",
    "build:sea": "pnpm build:bundle && node --experimental-sea-config sea-config.json && cp $(command -v node) dist/universe && npx postject dist/universe NODE_SEA_BLOB dist/sea-prep.blob --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "codegen": "node scripts/generate-layer-files.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "start": "node dist/bin.js",
    "test": "vitest run",
    "watch:unit": "vitest --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "lodash": "4.18.1",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/lodash": "4.17.24",
    "@types/node": "24.12.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.17.3",
    "picomatch": "4.0.4",
    "tsdown": "0.21.10",
    "typescript": "5.9.3",
    "vitest": "3.1.1"
  },
  "packageManager": "pnpm@10.32.1"
}
